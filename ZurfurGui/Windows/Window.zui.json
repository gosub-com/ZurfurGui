{
    ".controller": "Window",
    ".namespace": "ZurfurGui.Windows",
    ".classes": [ "Window" ],
    ".content": [
        {
            ".layout": "DockPanel",
            ".content": [
                {
                    ".name": "_windowTitle",
                    ".classes": [ "Window.Title" ],
                    ".layout": "DockPanel",
                    ".content": [
                        {
                            ".controller": "TextView",
                            ".classes": [ "Window.Title.TextColor", "Window.Title.Menu" ],
                            "dock.align": "left",
                            "text": "≡",
                            "font": { "size": 24.0 }
                        },
                        {
                            ".name": "_closeButton",
                            ".controller": "TextView",
                            ".classes": [ "Window.Title.TextColor", "Window.Title.Close" ],
                            "dock.align": "right",
                            "text": "X",
                            "font": { "size": 24.0 }
                        },
                        {
                            ".controller": "TextView",
                            ".name": "_title",
                            ".classes": [ "Window.Title.Text", "Window.Title.TextColor" ],
                            "text": "Hello",
                            ".disableHitTest": true
                        }
                    ]
                },
                {
                    ".name": "_windowContent",
                    ".classes": [ "Window.Content" ],
                    ".clip": true
                }
            ]
        },
        {
            ".name": "_resizeHandle",
            ".align": {
                "horizontal": "right",
                "vertical": "bottom"
            },
            ".margin": {
                "left": 0,
                "top": 0,
                "right": -5,
                "bottom": -13
            },
            ".content": [
                {
                    ".controller": "TextView",
                    "text": "◢",
                    ".offset": {
                        "x": -0.5,
                        "y": -1
                    },
                    "font": { "size": 32.0 }
                }
            ]
        }
    ]
}