{
    ".controller": "CheckBox",
    ".namespace": "ZurfurGui.Controls",
    ".layout": "Row",
    ".data": {
        "isChecked": {
            "type": "Bool"
        },
        "text": {
            "type": "TextLines",
            "bind": "_checkText.text"
        }
    },
    ".content": [
        {
            ".name": "_checkMark",
            ".controller": "TextView",
            "text": "[X]"
        },
        {
            ".name": "_checkText",
            ".controller": "TextView",
            "text": "CheckText"
        }
    ]
}