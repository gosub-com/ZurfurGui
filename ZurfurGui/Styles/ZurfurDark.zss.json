//
// Zurfur styles for dark mode
//
{
    "name": "ZurfurDark",
    "styles": [
        // AppWindow dark
        {
            ".selectors": "AppWindow:IsDarkMode",
            ".backgroundColor": "#1F1F1F"
        },
        // Text dark
        {
            ".selectors": "Text:IsDarkMode",
            "color": "#DDDDDD"
        },
        // Button dark
        {
            ".selectors": "Button:IsDarkMode",
            ".borderColor": "Gray",
            ".backgroundColor": "#505050",
            "color": "#F0F0F0"
        },
        // Button dark hover
        {
            ".selectors": "Button:IsDarkMode:IsPointerOver",
            ".borderColor": "#3C7FB1",
            ".backgroundColor": "#606060"
        },
        // Button dark pressed
        {
            ".selectors": "Button:IsDarkMode:IsPressed",
            ".borderColor": "#3C7FB1",
            ".backgroundColor": "#707070"
        },
        // Window dark
        {
            ".selectors": "Window:IsDarkMode",
            ".backgroundColor": "#383838",
            ".borderColor": "Gray"
        }
    ]
}