{
    ".controller": "MyCard",
    ".namespace": "TestApp.Controls",
    ".layout": "Column",
    ".data": {
        "title": {
            "type": "TextLines",
            "binding": "_bigTitle.text"
        },
        "card1": {
            "type": "IControlCardData"
        },
        "description": {
            "type": "TextLines",
            "binding": "_card2.description"
        },
        "byLine": {
            "type": "TextLines",
            "binding": "_card2.byLine"
        }

    },
    ".content": [
        {
            ".controller": "TextView",
            ".name": "_bigTitle",
            "text": "Default MyCard Title",
            "font": { "size": 34.0 }
        },
        {
            ".controller": "ControlCard",
            ".name": "_card1",
            "title": "Default MyCard.card1 title"
        },
        {
            ".controller": "ControlCard",
            ".name": "_card2",
            "title": "Default MyCard.card2 Title"
        }
    ]
}
