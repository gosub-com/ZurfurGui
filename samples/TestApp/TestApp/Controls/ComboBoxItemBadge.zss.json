{
    "name": "ComboBoxItemBadge",
    "styles": [
        {
            // Outer row: padding around the whole item
            ".selectors": "ComboBoxItemBadge",
            ".padding": "left:6;top:3;right:6;bottom:3"
        },
        {
            // Use Fluent token: color.brand.background.hover
            ".selectors": "ComboBoxItemBadge:IsPointerOver",
            ".backgroundColor": "@color.brand.background.hover"
        },
        {
            // Badge pill outline: 2px red border, small padding inside
            ".selectors": "ComboBoxItemBadge.BadgeBox",
            ".borderWidth": "@stroke.width.medium",
            ".borderColor": "@color.status.danger.stroke",
            ".borderRadius": "@radius.corner.small",
            ".padding": "left:4;top:1;right:4;bottom:1"
        },
        {
            // Badge text inside the pill
            ".selectors": "ComboBoxItemBadge.BadgeText",
            "TextView.color": "@color.status.danger.stroke"
        },
        {
            // Main descriptive text, with a small left gap from the badge
            ".selectors": "ComboBoxItemBadge.Text",
            "TextView.color": "@color.neutral.foreground1",
            ".padding": "left:6;top:0;right:0;bottom:0"
        }
    ]
}
