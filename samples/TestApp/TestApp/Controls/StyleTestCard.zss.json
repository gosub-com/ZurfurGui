//
// Zurfur styles for dark mode
//
{
    "name": "StyleTestCard",
    "styles": [
        {
            // StyleTestSkinThemeText: Light theme text styling
            ".selectors": "StyleTestSkinHoverText",
            "TextView.text": "Not hovering"
        },
        {
            // StyleTestSkinThemeText: Dark theme text styling
            ".selectors": "StyleTestSkinHoverText:IsPointerOver",
            "TextView.text": "Hovering"
        },
        {
            // StyleC1
            ".selectors": "StyleC1",
            ".sizeRequest": "width:120",
            "TextView.font": "size:28.0"
        },
        {
            // StyleC2
            ".selectors": "StyleC2",
            ".sizeRequest": "height:50",
            "TextView.font": "name:Times New Roman"
        }
    ]
}
