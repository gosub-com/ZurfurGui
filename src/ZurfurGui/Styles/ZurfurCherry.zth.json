// Fluent 2 starter token palette for ZurfurGui
{
    "name": "ZurfurCherry",

    "variables": {

        // Windows, Panels, Cards, etc.
        "color.surface.canvas": "#FAF2F5", // Main app window
        "color.surface.card": "#FCF8FA", // Panels, cards, etc. on top of main app window
        "color.surface.overlay": "#FEF9FB", // Windows and dialogs
        "color.surface.overlay.stroke": "#8B3058",
        "color.surface.overlay.scrim": "#00000050",

        // Window decorations
        "color.window.title.background": "#7A1035",
        "color.window.title.foreground": "White",
        "color.window.title.foreground.hover": "#FF1040",

        // Text
        "color.text.primary": "Black",
        "color.text.on-primary": "#3D1020",

        // Buttons, checkboxes, radio buttons, toggles, etc.
        "color.interactive.primary.background": "#F8D8E0",
        "color.interactive.primary.background.hover": "#F5E8EC",
        "color.interactive.primary.background.pressed": "#FDEAF0",
        "color.interactive.primary.background.selected": "#F8D8E0",
        "color.interactive.primary.stroke": "#C090A0",
        "color.interactive.primary.stroke.hover": "#B0304A",
        "color.interactive.primary.stroke.pressed": "#202880",

        // Text box, etc.
        "color.input.background": "#FFFFFF",
        "color.input.stroke": "#8B3058",

        // ScrollBar
        "color.scroll.track.background": "#F5E8EC",
        "color.scroll.thumb.background": "#D0B8C0",
        "color.scroll.thumb.background.hover": "#C0A0B0",
        "color.scroll.thumb.background.pressed": "#A08090",
        "color.scroll.stroke": "#C090A0",

        "color.status.success.background": "#DFF6DD",
        "color.status.warning.background": "#FFF4CE",
        "color.status.danger.background": "#FDE7E9",
        "color.status.success.foreground": "#107C10",
        "color.status.warning.foreground": "#797775",
        "color.status.danger.foreground": "#A80000",
        "color.status.info.background": "#DCE0F8",
        "color.status.info.foreground": "#3840A0",
        "color.status.danger.stroke": "#A80000",
        "color.status.success.stroke": "#107C10",
        "color.status.warning.stroke": "#797775"

    }
}
