// Fluent 2 starter token palette for ZurfurGui
{
    "name": "ZurfurCherryDark",

    "variables": {

        // Windows, Panels, Cards, etc.
        "color.surface.canvas": "#2A1520", // Main app window
        "color.surface.card": "#2A1520", // Panels, cards, etc. on top of main app window
        "color.surface.overlay": "#381520", // Windows and dialogs
        "color.surface.overlay.stroke": "#7A3050",
        "color.surface.overlay.scrim": "#FFFFFF50",

        // Window decorations
        "color.window.title.background": "#6B1530",
        "color.window.title.foreground": "#FFE8EE",
        "color.window.title.foreground.hover": "#FF5070",

        // Main body text
        "color.text.foreground": "#F0D8E0",

        // Buttons, checkboxes, radio buttons, toggles, etc.
        "color.interactive.foreground.on-primary": "#D8EEFF",
        "color.interactive.primary.background": "#222448",
        "color.interactive.primary.background.hover": "#2A2E60",
        "color.interactive.primary.background.pressed": "#181C40",
        "color.interactive.primary.background.selected": "#2A2E60",
        "color.interactive.primary.stroke": "#5058A0",
        "color.interactive.primary.stroke.hover": "#5868C0",
        "color.interactive.primary.stroke.pressed": "#383E90",

        // Text box, etc.
        "color.input.background": "#2A1520",
        "color.input.stroke": "#7A3050",

        "color.status.success.background": "#27472A",
        "color.status.warning.background": "#4F442B",
        "color.status.danger.background": "#4B2323",
        "color.status.success.foreground": "#92D050",
        "color.status.warning.foreground": "#FFD700",
        "color.status.danger.foreground": "#FF5F56",
        "color.status.info.background": "#2A2E60",
        "color.status.info.foreground": "#D8EEFF",
        "color.status.danger.stroke": "#FF5F56",
        "color.status.success.stroke": "#92D050",
        "color.status.warning.stroke": "#FFD700"

    }
}
