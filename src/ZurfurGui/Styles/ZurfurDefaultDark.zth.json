// Fluent 2 starter token palette for ZurfurGui
{
    "name": "ZurfurDefaultDark",

    "variables": {

        // Windows, Panels, Cards, etc.
        "color.surface.canvas": "#252526", // Main app window
        "color.surface.card": "#252526", // Panels, cards, etc. on top of main app window
        "color.surface.overlay": "#2C2C2C", // Windows and dialogs
        "color.surface.overlay.stroke": "#4A7090",
        "color.surface.overlay.scrim": "#FFFFFF50",

        // Window decorations
        "color.window.title.background": "#1E3A5A",
        "color.window.title.foreground": "#E8EEFF",

        // Text
        "color.text.primary": "#D4D4D4",
        "color.text.on-primary": "#D4D4D4",

        // Buttons, checkboxes, radio buttons, toggles, etc.
        "color.interactive.primary.background": "#23406C",
        "color.interactive.primary.background.hover": "#295A96",
        "color.interactive.primary.background.pressed": "#18325A",
        "color.interactive.primary.background.selected": "#223A5E",
        "color.interactive.primary.stroke": "#3973B7",
        "color.interactive.primary.stroke.hover": "#4CA0D0",
        "color.interactive.primary.stroke.pressed": "#3A80B0",

        // Text box, etc.
        "color.input.background": "#252526",
        "color.input.stroke": "#4A7090",

        // ScrollBar
        "color.scroll.track.background": "#252526",
        "color.scroll.thumb.background": "#3A5F8F",
        "color.scroll.thumb.background.hover": "#4A749F",
        "color.scroll.thumb.background.pressed": "#5A89B0",
        "color.scroll.stroke": "#4A7090",

        "color.status.success.background": "#27472A",
        "color.status.warning.background": "#4F442B",
        "color.status.danger.background": "#4B2323",
        "color.status.success.foreground": "#92D050",
        "color.status.warning.foreground": "#FFD700",
        "color.status.danger.foreground": "#FF5F56",
        "color.status.info.background": "#223A5E",
        "color.status.info.foreground": "#82AFFF",
        "color.status.danger.stroke": "#FF5F56",
        "color.status.success.stroke": "#92D050",
        "color.status.warning.stroke": "#FFD700"

    }
}
