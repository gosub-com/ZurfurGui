{
    "name": "ZurfurDefault",
    "styles": [
        {
            ".selectors": "AppWindow",
            ".backgroundColor": "@color.surface.canvas"
        },
        {
            ".selectors": "TextView",
            "TextView.color": "@color.text.foreground"
        },
        {
            ".selectors": "Button",
            ".borderWidth": "@stroke.width.default",
            ".borderRadius": "@radius.corner.medium",
            ".borderColor": "@color.interactive.primary.stroke",
            ".backgroundColor": "@color.interactive.primary.background",
            ".padding": "@padding.button"
        },
        {
            ".selectors": "Button:IsPointerOver",
            ".borderColor": "@color.interactive.primary.stroke.hover",
            ".backgroundColor": "@color.interactive.primary.background.hover"
        },
        {
            ".selectors": "Button:IsPressed",
            ".borderColor": "@color.interactive.primary.stroke.pressed",
            ".backgroundColor": "@color.interactive.primary.background.pressed"
        },
        {
            ".selectors": "Button.Text",
            "TextView.color": "@color.interactive.foreground.on-primary"
        },
        {
            ".selectors": "Window",
            ".backgroundColor": "@color.surface.overlay",
            ".borderColor": "@color.surface.overlay.stroke",
            ".borderRadius": "@radius.corner.extra-large",
            ".borderWidth": "@stroke.width.medium",
            ".sizeMin": "@size.window.min"
        },
        {
            ".selectors": "Window.Title",
            ".padding": "@spacing.vertical.small | spacing.horizontal.medium",
            ".backgroundColor": "@color.window.title.background",
            ".borderRadius": "@radius.corner.large",
        },
        {
            ".selectors": "Window.Title.Text",
            "TextView.font": "@font.size.window.title"
        },
        {
            ".selectors": "Window.Title.TextColor",
            "TextView.color": "@color.window.title.foreground"
        },
        {
            ".selectors": "Window.Title.Close:IsPointerOver",
            "TextView.color": "@color.window.title.foreground.hover"
        },
        {
            ".selectors": "Window.Content",
            ".margin": "@spacing.large"
        },
        {
            ".selectors": "TextEdit",
            ".backgroundColor": "@color.input.background",
            ".borderWidth": "@stroke.width.default",
            ".borderColor": "@color.input.stroke",
            ".sizeMin": "@size.textedit.min",
            ".padding": "@padding.textedit"
        },
        {
            ".selectors": "TextEdit.Text",
            "TextView.color": "@color.text.foreground"
        },
        {
            ".selectors": "ComboBox",
            ".borderWidth": "@stroke.width.default",
            ".borderRadius": "@radius.corner.medium",
            ".borderColor": "@color.interactive.primary.stroke",
            ".backgroundColor": "@color.interactive.primary.background",
            ".padding": "@padding.combobox",
            "ComboBox.scrimColor": "@color.surface.overlay.scrim"
        },
        {
            ".selectors": "ComboBox:IsPointerOver",
            ".borderColor": "@color.interactive.primary.stroke.hover",
            ".backgroundColor": "@color.interactive.primary.background.hover"
        },
        {
            ".selectors": "ComboBox:IsPressed",
            ".borderColor": "@color.interactive.primary.stroke.pressed",
            ".backgroundColor": "@color.interactive.primary.background.pressed"
        },
        {
            ".selectors": "ComboBox.Text",
            "TextView.color": "@color.text.foreground"
        },
        {
            ".selectors": "ComboBox.Arrow",
            "TextView.color": "@color.text.foreground",
            ".padding": "@padding.combobox.arrow"
        },
        {
            ".selectors": "ComboBox.Dropdown",
            ".backgroundColor": "@color.surface.card",
            ".borderWidth": "@stroke.width.default",
            ".borderColor": "@color.input.stroke",
            ".borderRadius": "@radius.corner.medium"
        },
        {
            ".selectors": "ComboBoxItemText",
            ".padding": "left:8;top:4;right:8;bottom:4"
        },
        {
            ".selectors": "ComboBoxItemText:IsPointerOver",
            ".backgroundColor": "@color.interactive.primary.background.hover"
        },
        {
            ".selectors": "ComboBoxItemText.Text",
            "TextView.color": "@color.text.foreground"
        }
    ]
}
