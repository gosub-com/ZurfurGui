{
    "name": "ZurfurDefault",
    "styles": [
        {
            ".selectors": "AppWindow",
            ".backgroundColor": "@color.neutral.background1"
        },
        {
            ".selectors": "TextView",
            "TextView.color": "@color.neutral.foreground1"
        },
        {
            ".selectors": "Button",
            ".borderWidth": "@stroke.width.default",
            ".borderRadius": "@radius.corner.medium",
            ".borderColor": "@color.stroke.default",
            ".backgroundColor": "@color.brand.background",
            ".padding": "@padding.button"
        },
        {
            ".selectors": "Button:IsPointerOver",
            ".borderColor": "@color.brand.stroke1",
            ".backgroundColor": "@color.brand.background.hover"
        },
        {
            ".selectors": "Button:IsPressed",
            ".borderColor": "@color.brand.stroke2",
            ".backgroundColor": "@color.brand.background.pressed"
        },
        {
            ".selectors": "Button.Text",
            "TextView.color": "@color.neutral.foreground.onBrand"
        },
        {
            ".selectors": "Window",
            ".backgroundColor": "@color.neutral.background2",
            ".borderColor": "@color.neutral.stroke1",
            ".borderRadius": "@radius.corner.largeplus",
            ".borderWidth": "@stroke.width.medium",
            ".sizeMin": "@size.window.min"
        },
        {
            ".selectors": "Window.Title",
            ".padding": "left:10;top:4;right:10;bottom:0",
            ".backgroundColor": "@color.window.title.background",
            ".borderRadius": "@radius.corner.large",
            "dock.align": "top",
            ".align": "vertical:top"
        },
        {
            ".selectors": "Window.Title.Text",
            ".align": "horizontal:center;vertical:center",
            "TextView.font": "@font.size.window.title"
        },
        {
            ".selectors": "Window.Title.TextColor",
            "TextView.color": "@color.window.title.foreground"
        },
        {
            ".selectors": "Window.Title.Close:IsPointerOver",
            "TextView.color": "@color.window.title.foreground.hover"
        },
        {
            ".selectors": "Window.Content",
            ".margin": "@spacing.l"
        },
        {
            ".selectors": "TextEdit",
            ".backgroundColor": "@color.neutral.background3",
            ".borderWidth": "@stroke.width.default",
            ".borderColor": "@color.neutral.stroke1",
            ".sizeMin": "width:100",
            ".padding": "left:8;top:3;right:8;bottom:2"
        },
        {
            ".selectors": "TextEdit.Text",
            "TextView.color": "@color.neutral.foreground1"
        },
        {
            ".selectors": "ComboBox",
            ".borderWidth": "@stroke.width.default",
            ".borderRadius": "@radius.corner.medium",
            ".borderColor": "@color.stroke.default",
            ".backgroundColor": "@color.brand.background",
            ".padding": "left:8;top:3;right:6;bottom:2",
            "ComboBox.scrimColor": "@color.overlay.scrim"
        },
        {
            ".selectors": "ComboBox:IsPointerOver",
            ".borderColor": "@color.brand.stroke1",
            ".backgroundColor": "@color.brand.background.hover"
        },
        {
            ".selectors": "ComboBox:IsPressed",
            ".borderColor": "@color.brand.stroke2",
            ".backgroundColor": "@color.brand.background.pressed"
        },
        {
            ".selectors": "ComboBox.Text",
            "TextView.color": "@color.neutral.foreground1"
        },
        {
            ".selectors": "ComboBox.Arrow",
            "TextView.color": "@color.neutral.foreground1",
            ".padding": "left:4;top:0;right:0;bottom:0"
        },
        {
            ".selectors": "ComboBox.Dropdown",
            ".backgroundColor": "@color.neutral.background2",
            ".borderWidth": "@stroke.width.default",
            ".borderColor": "@color.neutral.stroke1",
            ".borderRadius": "@radius.corner.medium"
        },
        {
            ".selectors": "ComboBoxItemText",
            ".padding": "left:8;top:4;right:8;bottom:4"
        },
        {
            ".selectors": "ComboBoxItemText:IsPointerOver",
            ".backgroundColor": "@color.brand.background.hover"
        },
        {
            ".selectors": "ComboBoxItemText.Text",
            "TextView.color": "@color.neutral.foreground1"
        }
    ]
}
