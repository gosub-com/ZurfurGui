{
    ".controller": "Window",
    ".namespace": "ZurfurGui.Windows",
    ".classes": [ "Window" ], // TBD: Remove, as this is the element type (not class)
    ".content": [
        {
            ".layout": "Dock",
            ".content": [
                {
                    ".name": "_windowTitle",
                    ".classes": [ "Window.Title" ],
                    ".layout": "Dock",
                    ".align":  "vertical:top",
                    "dock.align": "top",
                    ".content": [
                        {
                            ".controller": "TextView",
                            ".classes": [ "Window.Title.TextColor", "Window.Title.Menu" ],
                            "dock.align": "left",
                            "text": "≡",
                            "font": "size:24"
                        },
                        {
                            ".name": "_closeButton",
                            ".controller": "TextView",
                            ".classes": [ "Window.Title.TextColor", "Window.Title.Close" ],
                            "dock.align": "right",
                            "text": "X",
                            "font": "size:24"
                        },
                        {
                            ".controller": "TextView",
                            ".name": "_title",
                            ".classes": [ "Window.Title.Text", "Window.Title.TextColor" ],
                            ".align": "horizontal:center;vertical:center",
                            "text": "(not set)",
                            ".disableHitTest": true
                        }
                    ]
                },
                {
                    ".name": "_windowContent",
                    ".classes": [ "Window.Content" ],
                    ".clip": true
                }
            ]
        },
        {
            ".name": "_resizeHandle",
            ".align": "horizontal:right;vertical:bottom",
            ".margin": "left:0;top:0;right:-5;bottom:-13",
            ".content": [
                {
                    ".controller": "TextView",
                    "text": "◢",
                    ".offset": "x:-0.5;y:-1",
                    "font": "size:32"
                }
            ]
        }
    ]
}