// A drop down combo box
{
    ".controller": "ComboBox<Item> where Item : ComboBoxItem",
    ".namespace": "ZurfurGui.Controls",
    ".classes": [ "ComboBox" ],
    ".layout": "Row",
    ".sizeMin": { "width": 80 },
    ".data": {
        // The list of data items in the combo box. 
        // For ComboBox<ComboBoxTextItem> the data type is `IComboBoxTextItemData`
        "items": {
            "type": "[]Item"
        },
        // The currently selected index, or NULL if nothing is selected.
        "selectedIndex": {
            "type": "?int",
            "bind": "new"
        }
    },
    ".content": [
        {
            ".name": "_selectedItem",
            ".controller": "Panel",
            ".classes": [ "ComboBox.Text" ],
            ".align": { "horizontal": "stretch", "vertical": "center" }
        },
        {
            ".name": "_arrow",
            ".controller": "TextView",
            ".classes": [ "ComboBox.Arrow" ],
            ".align": { "horizontal": "right", "vertical": "center" },
            "text": [ "▾" ]
        }
    ]
}
