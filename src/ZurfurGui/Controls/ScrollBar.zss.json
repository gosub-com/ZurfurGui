{
    "name": "ScrollBar",
    "styles": [
        {
            ".selectors": "ScrollBar",
            "ScrollBar.trackColor": "@color.scroll.track.background",
            "ScrollBar.thumbColor": "@color.scroll.thumb.background",
            "ScrollBar.borderColor": "@color.scroll.stroke",
            "ScrollBar.borderWidth": "@stroke.width.default",
            "ScrollBar.thumbRadius": "@radius.scroll.thumb"
        },
        {
            ".selectors": "ScrollBar:IsPointerOver",
            "ScrollBar.thumbColor": "@color.scroll.thumb.background.hover"
        }
    ]
}
